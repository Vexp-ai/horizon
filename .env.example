# Copy to `.env` and fill in. Do NOT commit `.env` (see .gitignore).
# The OpenRouter key is only needed for the DeepSeek ceilings (§9).

OPENROUTER_API_KEY=

# OpenRouter base URL (openai-compatible). Normally unchanged.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ceiling model ID (§9). VERIFY on OpenRouter that the ID is current.
DEEPSEEK_CEILING_MODEL=deepseek/deepseek-v4-flash

# Additional ceiling: R1, "the teacher" of the distilled base.
# Verified on OpenRouter: deepseek/deepseek-r1-0528 also exists (newer revision).
DEEPSEEK_R1_MODEL=deepseek/deepseek-r1

# Local vLLM server endpoint (GPU tier) used by the harness.
VLLM_BASE_URL=http://localhost:8000/v1

# HuggingFace token (for gated datasets/models). Optional.
HF_TOKEN=
